# ============================================================
# SNS Affiliate Bot - Environment Variables
# コピーして .env に名前を変更し、各値を入力してください
# ============================================================

# ---- Meta Graph API (Threads + Instagram) ------------------
# Meta for Developers でアプリ作成後に取得
META_APP_ID=
META_APP_SECRET=

# 転職ジャンル用 Threads アカウント
THREADS_CAREER_USER_ID=
THREADS_CAREER_ACCESS_TOKEN=

# 将来追加: 各ジャンルのトークン
# THREADS_BEAUTY_USER_ID=
# THREADS_BEAUTY_ACCESS_TOKEN=
# THREADS_FINANCE_USER_ID=
# THREADS_FINANCE_ACCESS_TOKEN=
# THREADS_VOD_USER_ID=
# THREADS_VOD_ACCESS_TOKEN=
# THREADS_EDUCATION_USER_ID=
# THREADS_EDUCATION_ACCESS_TOKEN=

# Instagram（将来用）
# META_INSTAGRAM_CAREER_BUSINESS_ID=

# ---- YouTube Data API --------------------------------------
# Google Cloud Console で OAuth2.0 認証情報を作成後に設定
# 各ジャンルで credentials JSON ファイルを使うため、ここはチャンネルIDのみ
YOUTUBE_CAREER_CHANNEL_ID=UC65pP_901i2ERosuStSAIVw
# YOUTUBE_BEAUTY_CHANNEL_ID=
# YOUTUBE_FINANCE_CHANNEL_ID=
# YOUTUBE_VOD_CHANNEL_ID=
# YOUTUBE_EDUCATION_CHANNEL_ID=

# ---- Pexels API (無料) -------------------------------------
# https://www.pexels.com/api/ で取得（無料）
PEXELS_API_KEY=

# ---- A8.net アフィリエイト ---------------------------------
# A8.net 管理画面で確認
A8_AFFILIATE_ID=

# ---- VOICEVOX (ローカル実行) --------------------------------
# VOICEVOX を起動すると localhost:50021 で動作
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_ID=1

# ---- TikTok Content Posting API ----------------------------
# https://developers.tiktok.com → My Apps → App Keys
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ---- AI プロバイダー設定 ------------------------------------
# 現在: template（追加コストゼロ）
# 将来: claude / grok / openai
AI_PROVIDER=template

# 将来の拡張用（今は空でOK）
# ANTHROPIC_API_KEY=
# XAI_API_KEY=        # Grok (xAI)
# OPENAI_API_KEY=     # OpenAI Codex
